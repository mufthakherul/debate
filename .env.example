# Root environment variables for Docker deployments
POSTGRES_USER=debate_user
POSTGRES_PASSWORD=debate_pass
POSTGRES_DB=debate_db
POSTGRES_PORT=5432

API_PORT=8000
WEB_PORT=3000

DATABASE_URL=postgresql://debate_user:debate_pass@postgres:5432/debate_db?schema=public
JWT_SECRET=your-jwt-secret-key-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
PASSWORD_RESET_TTL=1h
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
VITE_API_URL=http://localhost:8000
