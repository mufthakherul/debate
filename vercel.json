{
  "version": 2,
  "builds": [
    {
      "src": "api/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["api/prisma/schema.prisma"]
      }
    },
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/web/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/web/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}

