# Vercel Environment Variables Template
# Copy these to your Vercel project settings: Project Settings → Environment Variables

# ======================================
# DATABASE
# ======================================
DATABASE_URL=postgresql://user:password@host:5432/database
# Example for Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb
# Example for Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# Example for Railway: postgresql://postgres:password@containers-us-west-xxx.railway.app:7432/railway

# ======================================
# AUTHENTICATION
# ======================================
# Generate secure secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
REFRESH_TOKEN_SECRET=your-super-secret-refresh-key-min-32-chars-change-this

# Token expiration times
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
PASSWORD_RESET_TTL=1h

# ======================================
# API CONFIGURATION
# ======================================
NODE_ENV=production
PORT=3001

# ======================================
# CORS CONFIGURATION
# ======================================
# Use your Vercel deployment URL (e.g., https://your-project.vercel.app)
CORS_ORIGIN=https://your-project.vercel.app
CORS_ALLOWED_ORIGINS=https://your-project.vercel.app

# ======================================
# WEB APP (FRONTEND)
# ======================================
# Use your Vercel deployment URL (e.g., https://your-project.vercel.app)
VITE_API_URL=https://your-project.vercel.app

# ======================================
# NOTES
# ======================================
# 1. Replace all placeholder values before deploying
# 2. Generate JWT secrets using the command provided above
# 3. After first deployment, update VITE_API_URL with your actual Vercel URL
# 4. If using a custom domain, update all URLs accordingly
# 5. Keep these variables secret - never commit them to Git
